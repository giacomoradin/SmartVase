// =====================================================================
// secrets.h.example — TEMPLATE for the Hub credentials.
//
// USAGE: copy this file to `secrets.h` (same folder) and fill in the real
// values. `secrets.h` is GITIGNORED: passwords never end up in the repo.
// Without `secrets.h` the Hub build fails on purpose, reminding you to
// create it.
//
//   cp secrets.h.example secrets.h   # then edit secrets.h
// =====================================================================
#ifndef SMARTVASE_HUB_SECRETS_H
#define SMARTVASE_HUB_SECRETS_H

#define SV_WIFI_SSID    "YOUR_WIFI_SSID"
#define SV_WIFI_PASS    "YOUR_WIFI_PASSWORD"
#define SV_MQTT_BROKER  "xxxxxxxx.s1.eu.hivemq.cloud"
#define SV_MQTT_PORT    8883
#define SV_MQTT_USER    "YOUR_MQTT_USER"
#define SV_MQTT_PASS    "YOUR_MQTT_PASSWORD"

// Password for the Hub OTA (Over-The-Air) update.
#define SV_OTA_PASS     "CHANGE_ME_OTA_PASSWORD"

#endif // SMARTVASE_HUB_SECRETS_H
