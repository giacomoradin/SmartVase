// =====================================================================
// secrets.h.example — TEMPLATE delle credenziali dell'Hub.
//
// USO: copia questo file in `secrets.h` (stessa cartella) e inserisci i
// valori reali. `secrets.h` e' GITIGNORATO: le password non finiscono mai
// nel repo (contesto accademico). Senza `secrets.h` la build dell'Hub
// fallisce di proposito, ricordandoti di crearlo.
//
//   cp secrets.h.example secrets.h   # poi edita secrets.h
// =====================================================================
#ifndef SMARTVASE_HUB_SECRETS_H
#define SMARTVASE_HUB_SECRETS_H

#define SV_WIFI_SSID    "YOUR_WIFI_SSID"
#define SV_WIFI_PASS    "YOUR_WIFI_PASSWORD"
#define SV_MQTT_BROKER  "xxxxxxxx.s1.eu.hivemq.cloud"
#define SV_MQTT_PORT    8883
#define SV_MQTT_USER    "YOUR_MQTT_USER"
#define SV_MQTT_PASS    "YOUR_MQTT_PASSWORD"

// Password per l'update OTA (Over-The-Air) dell'Hub.
#define SV_OTA_PASS     "CHANGE_ME_OTA_PASSWORD"

#endif // SMARTVASE_HUB_SECRETS_H
